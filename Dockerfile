# 1. ベースとなる環境（キッチン）を指定：軽量なGo環境を採用
FROM golang:1.25-alpine

# 2. コンテナの中の作業ディレクトリ（調理場）を設定
WORKDIR /app

# 3. 必要なパッケージの設計図を先にコピーしてダウンロード（準備）
COPY go.mod go.sum ./
RUN go mod download

# 4. あなたが書いたGoのコードを全てコンテナの中にコピー
COPY . .

# 5. Goのプログラムをビルド（実行ファイルに変換）
RUN go build -o main .

# 6. このコンテナを動かす時に、どのポート（窓口）を開けるか明記
EXPOSE 8080

# 7. コンテナが起動した時の最初の命令（サーバー起動！）
CMD ["./main"]